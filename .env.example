DATABASE_URL="file:./prisma/dev.db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
INTERNAL_JOB_SECRET="replace-with-a-long-random-secret"
MOBILE_SUBSCRIPTION_WEBHOOK_SECRET="replace-with-a-long-random-secret"

# Optional auth abuse overrides
# AUTH_ABUSE_SIGNIN_MAX_ATTEMPTS="5"
# AUTH_ABUSE_SIGNIN_WINDOW_MS="900000"
# AUTH_ABUSE_SIGNIN_LOCKOUT_MS="900000"

# Optional API rate limit overrides
# RATE_LIMIT_DIARY_MAX_REQUESTS="60"
# RATE_LIMIT_RECOMMENDATIONS_PATCH_MAX_REQUESTS="30"