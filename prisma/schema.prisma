generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Tier {
  LIFE_SONG
  ELITE
  HEAVY_ROTATION
  LIKED
  NOT_FOR_ME
}

enum RecommendationStatus {
  ACTIVE
  SAVED
  DISMISSED
}

model User {
  id             String            @id @default(cuid())
  email          String            @unique
  name           String
  passwordHash   String
  privacyDefault String            @default("private")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  diaryEntries   DiaryEntry[]
  trackScores    UserTrackScore[]
  comparisons    RankingComparison[]
  recommendations Recommendation[]
  weeklyRecaps   WeeklyRecap[]
}

model Artist {
  id      String  @id @default(cuid())
  name    String  @unique
  era     String
  tracks  Track[]
  albums  Album[]
}

model Album {
  id       String  @id @default(cuid())
  title    String
  year     Int
  coverUrl String
  artistId String
  artist   Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  tracks   Track[]
}

model Track {
  id             String             @id @default(cuid())
  title          String
  genre          String
  era            String
  year           Int
  albumArtUrl    String
  artistId       String
  albumId        String
  artist         Artist             @relation(fields: [artistId], references: [id], onDelete: Cascade)
  album          Album              @relation(fields: [albumId], references: [id], onDelete: Cascade)
  diaryEntries   DiaryEntry[]
  userTrackScore UserTrackScore[]
  recommendations Recommendation[]
  topSongWeeks   WeeklyRecap[]
}

model DiaryEntry {
  id        String      @id @default(cuid())
  userId    String
  trackId   String
  tier      Tier
  note      String?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  track     Track       @relation(fields: [trackId], references: [id], onDelete: Cascade)
  tags      EntryTag[]

  @@index([userId, createdAt])
}

model TasteTag {
  id        String     @id @default(cuid())
  name      String     @unique
  category  String     @default("mood")
  entryTags EntryTag[]
}

model EntryTag {
  entryId String
  tagId   String
  entry   DiaryEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag     TasteTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([entryId, tagId])
}

model UserTrackScore {
  id              String   @id @default(cuid())
  userId          String
  trackId         String
  score           Float
  tier            Tier
  manualReplayCount Int    @default(0)
  lastInteractedAt DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track           Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([userId, score])
}

model RankingComparison {
  id            String   @id @default(cuid())
  userId        String
  leftTrackId   String
  rightTrackId  String
  winnerTrackId String
  loserTrackId  String
  delta         Float
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Recommendation {
  id        String               @id @default(cuid())
  userId    String
  trackId   String
  score     Float
  reason    String
  status    RecommendationStatus @default(ACTIVE)
  createdAt DateTime             @default(now())
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  track     Track                @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
}

model WeeklyRecap {
  id         String   @id @default(cuid())
  userId     String
  weekStart  DateTime
  topSongId  String?
  topMood    String
  topGenre   String
  summary    String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topSong    Track?   @relation(fields: [topSongId], references: [id], onDelete: SetNull)

  @@unique([userId, weekStart])
}
