{
  "expo": {
    "name": "Basso",
    "slug": "basso-mobile",
    "scheme": "basso",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "replace-with-your-eas-project-id"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.basso.mobile",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "Basso uses notifications to remind you about new recommendations and weekly recaps."
      }
    },
    "android": {
      "package": "app.basso.mobile",
      "googleServicesFile": "./google-services.json"
    }
  }
}